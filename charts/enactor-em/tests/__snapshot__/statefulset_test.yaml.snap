matches the rendered snapshot:
  1: |
    apiVersion: apps/v1
    kind: StatefulSet
    metadata:
      labels:
        app.kubernetes.io/instance: em
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: ema
        app.kubernetes.io/version: "1.0"
        helm.sh/chart: enactor-em-0.5.6
      name: ema
    spec:
      replicas: 1
      selector:
        matchLabels:
          app.kubernetes.io/instance: em
          app.kubernetes.io/name: ema
      serviceName: ema
      template:
        metadata:
          annotations:
            checksum/common: 3385db082ae6c9bb3e8b6e4276af64820d74a7f077e66928f714bcab8bfed2c2
            checksum/ema: b8d03abb608bf4fea644590d7636b040ed032b547e3784e010f0d263d5a7b9bd
          labels:
            app.kubernetes.io/instance: em
            app.kubernetes.io/name: ema
        spec:
          automountServiceAccountToken: false
          containers:
            - env:
                - name: ENACTOR_DB_USER
                  value: enactor
                - name: ENACTOR_DB_PASS
                  valueFrom:
                    secretKeyRef:
                      key: mariadb-password
                      name: em-secrets
                - name: ENACTOR_RMI_SERVERHOST
                  valueFrom:
                    fieldRef:
                      fieldPath: status.podIP
              envFrom:
                - configMapRef:
                    name: config-common
                - configMapRef:
                    name: config-ema
                - secretRef:
                    name: secret-common
              image: registry.example.com/enactor/ema:latest
              imagePullPolicy: Always
              livenessProbe:
                failureThreshold: 5
                periodSeconds: 15
                tcpSocket:
                  port: http
                timeoutSeconds: 5
              name: ema
              ports:
                - containerPort: 39830
                  name: http
                  protocol: TCP
              readinessProbe:
                failureThreshold: 5
                periodSeconds: 15
                tcpSocket:
                  port: http
                timeoutSeconds: 5
              resources: {}
              securityContext: {}
              startupProbe:
                failureThreshold: 30
                initialDelaySeconds: 20
                periodSeconds: 10
                tcpSocket:
                  port: http
              volumeMounts:
                - mountPath: /enactor/app/home
                  name: apphome
          initContainers:
            - command:
                - sh
                - -c
                - |-
                  sleep $INTERVAL;
                  echo -e "Checking for the availability of '$HOST' on port $PORT";
                  while ! nc -z $HOST $PORT;
                    do sleep $INTERVAL;
                    printf "-";
                  done;
                  echo -e "  >> Service '$HOST' has started";
              env:
                - name: HOST
                  value: emp
                - name: PORT
                  value: "39832"
                - name: INTERVAL
                  value: "2"
              image: busybox:1.31
              imagePullPolicy: IfNotPresent
              name: depends-on
              resources:
                limits:
                  cpu: 50m
                  memory: 200Mi
                requests:
                  cpu: 10m
                  memory: 20Mi
              securityContext: {}
          securityContext:
            fsGroup: 1100
          serviceAccountName: ema
          terminationGracePeriodSeconds: 300
      updateStrategy:
        rollingUpdate:
          maxUnavailable: 1
        type: RollingUpdate
      volumeClaimTemplates:
        - metadata:
            name: apphome
          spec:
            accessModes:
              - ReadWriteOnce
            resources:
              requests:
                storage: 25Gi
            storageClassName: test-sc
